# Copy to .env.microservices and adjust as needed
SPRING_PROFILES_ACTIVE=dev

# Eureka
EUREKA_SERVER_PORT=8761
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka/

# API Gateway
API_GATEWAY_PORT=8081
QUANTITY_SERVICE_NAME=quantity-measurement-app

# Redis (for gateway RequestRateLimiter)
REDIS_PORT=6379
GATEWAY_RETRY_RETRIES=2
GATEWAY_AUTH_RATE_PER_SEC=20
GATEWAY_AUTH_BURST_CAPACITY=40
GATEWAY_QUANTITY_RATE_PER_SEC=30
GATEWAY_QUANTITY_BURST_CAPACITY=60

