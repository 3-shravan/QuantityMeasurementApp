### Gateway-wide API checks (port 8080)
### Run top-to-bottom in IntelliJ HTTP Client.

@gatewayBase = http://localhost:8080
@contentType = application/json

# Use unique values on each run to avoid conflict errors unless you are testing duplicates.
@username = gw_user_{{$timestamp}}
@email = gw_user_{{$timestamp}}@example.com
@password = Password123

### 1) Gateway health (expect 200)
GET {{gatewayBase}}/actuator/health
Accept: application/json

> {%
client.test("gateway health should be UP", function() {
  client.assert(response.status === 200, "Expected 200 from gateway health");
  client.assert(response.body.status === "UP", "Expected gateway status UP");
});

client.global.set("gwUsername", request.variables.get("username"));
client.global.set("gwEmail", request.variables.get("email"));
if (!client.global.get("gwToken")) {
  client.global.set("gwToken", "INVALID_TOKEN");
}
%}

###
### 2) Register via gateway (expect 201)
POST {{gatewayBase}}/api/v1/auth/register
Content-Type: {{contentType}}

{
  "username": "{{username}}",
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
client.test("register returns 201 with token", function() {
  client.assert(response.status === 201, "Expected 201 from register");
  client.assert(response.body.token, "Expected token in register response");
  client.assert(response.body.username, "Expected username in register response");
  client.assert(response.body.email, "Expected email in register response");
});

if (response.status === 201 && response.body.token) {
  client.global.set("gwToken", response.body.token);
  client.global.set("gwUsername", response.body.username);
  client.global.set("gwEmail", response.body.email);
}
%}

###
### 3) Login via username (expect 200)
POST {{gatewayBase}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "username": "{{gwUsername}}",
  "password": "{{password}}"
}

> {%
client.test("username login returns 200 with token", function() {
  client.assert(response.status === 200, "Expected 200 from login by username");
  client.assert(response.body.token, "Expected token in login response");
});

if (response.status === 200 && response.body.token) {
  client.global.set("gwToken", response.body.token);
}
%}


###
### 5) Duplicate register (expect 409 with JSON error payload)
POST {{gatewayBase}}/api/v1/auth/register
Content-Type: {{contentType}}

{
  "username": "{{gwUsername}}",
  "email": "{{gwEmail}}",
  "password": "{{password}}"
}

> {%
client.test("duplicate register returns 409 JSON error", function() {
  client.assert(response.status === 409, "Expected 409 from duplicate register");
  client.assert(response.body.timestamp, "Expected timestamp in error response");
  client.assert(response.body.status === 409, "Expected status field 409");
  client.assert(response.body.error, "Expected error field");
  client.assert(response.body.message, "Expected message field");
  client.assert(response.body.path, "Expected path field");
});
%}

###
### 6) Invalid login payload (expect 400 with JSON error payload)
POST {{gatewayBase}}/api/v1/auth/login
Content-Type: {{contentType}}

{
  "password": "{{password}}"
}

> {%
client.test("invalid login payload returns 400 JSON error", function() {
  client.assert(response.status === 400, "Expected 400 from invalid login payload");
  client.assert(response.body.status === 400, "Expected status field 400");
  client.assert(response.body.message, "Expected message field");
  client.assert(response.body.path, "Expected path field");
});
%}

###
### 7) OAuth2 login with fake token (expect 4xx with JSON error payload)
POST {{gatewayBase}}/api/v1/auth/oauth2/google
Content-Type: {{contentType}}

{
  "provider": "google",
  "accessToken": "fake_google_access_token"
}

> {%
client.test("oauth2 invalid token returns client error JSON", function() {
  client.assert(response.status >= 400 && response.status < 500, "Expected 4xx from fake oauth2 token");
  client.assert(response.body.status, "Expected status field");
  client.assert(response.body.error, "Expected error field");
  client.assert(response.body.message, "Expected message field");
  client.assert(response.body.path, "Expected path field");
});
%}

###
### 8) Quantity compare (expect 200)
POST {{gatewayBase}}/api/v1/quantities/compare
Content-Type: {{contentType}}
Authorization: Bearer {{gwToken}}

{
  "thisQuantityDTO": {
    "value": 30.48,
    "unit": "CENTIMETERS",
    "measurementType": "LengthUnit"
  },
  "thatQuantityDTO": {
    "value": 1,
    "unit": "FEET",
    "measurementType": "LengthUnit"
  }
}

> {%
client.test("quantity compare returns 200", function() {
  client.assert(response.status === 200, "Expected 200 from compare");
});
%}

