###
### 18) Quantity guest history is empty (expect 200 with [])
GET {{gatewayBase}}/api/v1/quantities/history/errored

> {%
client.test("guest errored history returns empty list", function() {
  client.assert(response.status === 200, "Expected 200 from guest errored history");
  client.assert(Array.isArray(response.body), "Expected array response for guest history");
  client.assert(response.body.length === 0, "Expected empty history for guest");
});
%}

###
### 19) Quantity validation error (expect 400 with JSON error payload)
